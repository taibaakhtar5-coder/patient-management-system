@model IEnumerable<HealthcareCRM.Models.Patient>

@{
    ViewData["Title"] = "Patient Directory";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Patient Management Directory</h2>
        <a href="/Patients/Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add New Patient</a>
    </div>

    <!-- Search Bar Form (Section 3.1 Requirement) -->
    <form method="get" action="/api/patients" class="mb-4">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Search patients by name..." />
            <button class="btn btn-outline-secondary" type="submit">Search</button>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Full Name</th>
                        <th>Age</th>
                        <th>Gender</th>
                        <th>Contact Number</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Runtime/In-Memory Loop Simulation -->
                    <tr>
                        <td>1</td>
                        <td>Zain Abideen</td>
                        <td>24</td>
                        <td>Male</td>
                        <td>03001234567</td>
                        <td>
                            <a href="/Patients/Edit/1" class="btn btn-sm btn-outline-warning">Edit</a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>